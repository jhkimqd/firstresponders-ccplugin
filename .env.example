# Copy to `.env` and fill in. Never commit the real .env.
#
# GitHub token for ingesting Bor / Heimdall-v2 commits and PRs.
# Personal access token with `public_repo` scope is sufficient.
# If unset, github_ingest falls back to unauthenticated access (60 req/hr).
GITHUB_TOKEN=

# Polygon PoS JSON-RPC endpoint used by `polygon-frp-rpc` MCP and investigate-blocks.
# Default public RPC works but is rate-limited; prefer an internal or Alchemy/Infura URL.
POLYGON_RPC_URL=https://polygon.drpc.org

# Datadog is NOT configured here — it is a Claude-managed MCP that each responder
# authenticates through their Claude account (Settings -> Integrations -> Datadog).
# See README.md "Connecting the Datadog MCP" for setup.
